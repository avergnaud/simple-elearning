# /etc/nginx/sites-available/elearning
# Managed by Ansible — do not edit manually.
#
# ssl_cert_exists = {{ ssl_cert_exists }}
# Generated by the nginx role; see ansible/roles/nginx/templates/elearning.conf.j2
{% if ssl_cert_exists %}

# =============================================================================
# Block 1 — HTTP: permanent redirect to HTTPS
# =============================================================================
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }} www.{{ domain }};

    # Redirect all HTTP traffic (including any Certbot ACME renewal probes)
    # to the canonical HTTPS URL. The 301 is permanent and cacheable.
    return 301 https://{{ domain }}$request_uri;
}

# =============================================================================
# Block 2 — HTTPS: main application server
# =============================================================================
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ domain }} www.{{ domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Enforce HTTPS for one year — enable only after verifying TLS works.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Django-collected static assets.
    # Long cache lifetime is safe because Django appends content-hash query strings.
    location /static/ {
        alias   {{ static_root }}/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # User-uploaded media files.
    location /media/ {
        alias   {{ media_root }}/;
        expires 7d;
        add_header Cache-Control "public";
    }

    # Everything else is proxied to Gunicorn.
    location / {
        proxy_pass         http://{{ gunicorn_bind }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_redirect     off;
        proxy_read_timeout 60s;
    }
}

{% else %}
# =============================================================================
# HTTP only — bootstrapping configuration (certificate not yet provisioned)
# =============================================================================
# The Let's Encrypt certificate does not exist yet. This temporary server block
# allows Certbot to complete the ACME HTTP-01 challenge on port 80 and also
# serves the application over plain HTTP during the first provisioning run.
#
# After the ssl role obtains the certificate, Ansible re-applies this template
# with ssl_cert_exists=true, switching to the HTTP-redirect + HTTPS layout above.
# =============================================================================
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }} www.{{ domain }};

    location /static/ {
        alias {{ static_root }}/;
    }

    location /media/ {
        alias {{ media_root }}/;
    }

    location / {
        proxy_pass         http://{{ gunicorn_bind }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_redirect     off;
    }
}
{% endif %}
